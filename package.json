{
  "name": "ccccocc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:generate": "wrangler types --env-file .dev.vars.example",
